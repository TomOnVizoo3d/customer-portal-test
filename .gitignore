# Application
# Ignore all unknown folders e.g. the ones created by cookie banner
web/app/*
!web/app/mu-plugins
!web/app/plugins
!web/app/themes
# 
#
#
web/app/plugins/*
!web/app/plugins/.gitkeep
!web/app/plugins/vizoo-*
!web/app/plugins/ajax-search-pro
